# Copy to .env.local. NEVER commit real values. No PHI anywhere in env or logs.
#
# The app runs entirely on in-memory stores until you switch these on, so none of
# these are required for local dev.

# ── Reference data (plans/networks/formularies) ──────────────────────────────
# Stays bundled + git-versioned (lib/data/source/). "fixtures" is the only mode.
DATA_STORE=fixtures

# ── PHI persistence spine (sessions / profiles / audit) ───────────────────────
# "memory" (default) keeps state in-process; "supabase" persists to Postgres+RLS.
# Setting "supabase" ALSO turns on broker auth: middleware gates /, /session,
# /audit and the broker APIs, redirecting to /login. A signed-in broker's first
# request auto-provisions their organization + brokers row (see lib/supabase/auth.ts).
# Requires the three keys below.
STATE_STORE=memory

# Supabase project. NEXT_PUBLIC_* are safe in the browser; the SERVICE_ROLE key
# is SERVER-ONLY (used solely for the patient-intake capability path) — never
# expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI health-future simulation (opt-in, SERVER-ONLY) ─────────────────────────
# The ONLY LLM-powered feature, and it sits OUTSIDE the recommendation data path
# (ARCHITECTURE.md invariant #6): Claude interprets the deterministic Monte-Carlo
# health projection into a 5- and 10-year narrative. The app runs fully without
# this key; the engine + audit never depend on it. Only DE-IDENTIFIED clinical
# facts are sent (lib/sim/deidentify.ts). NOT prefixed NEXT_PUBLIC_ — never ship
# this key to the browser.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
SIM_MODEL=
