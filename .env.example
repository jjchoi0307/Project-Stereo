# Copy to .env.local. NEVER commit real values. No PHI anywhere in env or logs.
#
# The app runs entirely on in-memory stores until you switch these on, so none of
# these are required for local dev.

# ── Reference data (plans/networks/formularies) ──────────────────────────────
# Stays bundled + git-versioned (lib/data/source/). "fixtures" is the only mode.
DATA_STORE=fixtures

# ── PHI persistence spine (sessions / profiles / audit) ───────────────────────
# "memory" (default) keeps state in-process; "supabase" persists to Postgres+RLS.
# Setting "supabase" ALSO turns on broker auth: middleware gates /, /session,
# /audit and the broker APIs, redirecting to /login. A signed-in broker's first
# request auto-provisions their organization + brokers row (see lib/supabase/auth.ts).
# Requires the three keys below.
STATE_STORE=memory

# Supabase project. NEXT_PUBLIC_* are safe in the browser; the SERVICE_ROLE key
# is SERVER-ONLY (used solely for the patient-intake capability path) — never
# expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI features (opt-in, SERVER-ONLY) ─────────────────────────────────────────
# Powers the grounded recommendation (Claude ranks the ELIGIBLE plans and writes
# the cited reasons, reasoning only over the real plan files — it can't include an
# ineligible plan or invent a figure), plus the clinical read and the 3-/5-year
# health-futures narrative over the deterministic projection. The deterministic
# eligibility gate, engine, and audit never depend on this key — the app runs fully
# without it. Only DE-IDENTIFIED facts are sent (lib/sim/deidentify.ts). NOT
# prefixed NEXT_PUBLIC_ — never ship this key to the browser.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6).
SIM_MODEL=

# ── Access control ────────────────────────────────────────────────────────────
# Self-service broker sign-up. OFF by default (HIPAA §164.308(a)(4) — access
# establishment must be controlled): a self-signup becomes org_admin of a new org,
# so leave this unset in production and provision brokers deliberately. Set "true"
# only for demo/dev.
ALLOW_SIGNUP=

# Single-org broker model
SMG_ORG_ID=
ORG_ADMIN_EMAILS=

# ── Audit integrity ───────────────────────────────────────────────────────────
# Server-held secret for the audit-record HMAC (tamper-evidence over the stored
# payload — AI recommendation, citations, PHI snapshot). When set, new records
# are signed and /verify flags any later alteration. When UNSET, records are left
# unsigned and verification degrades gracefully to reproducibility-only — so this
# is a pure config toggle, never required for the app to run. Use a long random
# value (e.g. `openssl rand -base64 48`); NOT prefixed NEXT_PUBLIC_ — server only.
AUDIT_HMAC_KEY=
